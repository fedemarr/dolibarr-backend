# Copiar estas variables en Railway → tu servicio → Variables
# Las marcadas con (*) las provee Railway automaticamente con sus plugins

SECRET_KEY=generar_con_python_-c_"import_secrets;print(secrets.token_hex(32))"
ENVIRONMENT=production
LOG_LEVEL=INFO

# (*) Railway Postgres plugin — provee DATABASE_URL automaticamente
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD no hacen falta si usas DATABASE_URL
DB_HOST=
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=

# (*) Railway Redis plugin — provee REDIS_URL automaticamente
REDIS_URL=redis://...

DOLIBARR_URL=https://dolibarr.tuempresa.com
DOLIBARR_API_KEY=reemplazar_con_clave_real

AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_S3_BUCKET=dolibarr-pdfs
AWS_REGION=sa-east-1

RESEND_API_KEY=placeholder
SLACK_WEBHOOK_URL=placeholder

# URL del frontend en Vercel (para CORS)
FRONTEND_URL=https://dolibarr-frontend.vercel.app

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
